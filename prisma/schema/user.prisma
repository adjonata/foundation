enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String?
  passwordHash String
  role         Role          @default(USER)
  authSessions AuthSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}
